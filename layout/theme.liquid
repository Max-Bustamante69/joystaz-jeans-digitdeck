<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'styles.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
    <!-- Swiper.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

    <!-- HLS.js for video streaming -->
    <script defer src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

    <!-- Alpine.js -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="{{ 'infinite-scroll.js' | asset_url }}" defer="defer"></script>
  </head>

  <body>
    {% sections 'header-group' %}
    <div class="-mt-23">
      {{ content_for_layout }}
    </div>

    {% sections 'footer-group' %}

    <!-- Cart Drawer -->
    {% sections 'cart-drawer-group' %}

    <!-- Search Drawer -->
    {% sections 'search-drawer-group' %}

    <script>
      (() => {
        const knownLockClasses = [
          'mobile-menu-open',
          'cart-drawer-open',
          'search-drawer-open',
          'filter-drawer-open',
          'product-gallery-open',
          'video-gallery-open',
          'look-fit-gallery-open',
        ];
        const activeLocks = new Set();

        const hasKnownClassLock = () =>
          knownLockClasses.some((className) => document.body.classList.contains(className));

        const syncAnnouncementOffset = () => {
          const tickerSection = document.querySelector('.shopify-section-group-header-group[id*="__ticker"]');
          const announcementBar = tickerSection ? tickerSection.querySelector('[data-announcement-bar]') : null;
          const offset = announcementBar ? Math.round(announcementBar.getBoundingClientRect().height) : 0;
          document.documentElement.style.setProperty('--announcement-bar-offset', `${offset}px`);
        };

        const hasVisibleFullscreenOverlay = () => {
          const overlayCandidates = document.querySelectorAll('[data-scroll-lock-overlay]');
          return Array.from(overlayCandidates).some((element) => {
            const styles = window.getComputedStyle(element);
            if (styles.display === 'none' || styles.visibility === 'hidden' || styles.opacity === '0') {
              return false;
            }

            const rect = element.getBoundingClientRect();
            return (
              rect.width >= window.innerWidth * 0.9
              && rect.height >= window.innerHeight * 0.9
            );
          });
        };

        const clearStaleClassLocks = (reason = 'unknown') => {
          if (!document.body || activeLocks.size > 0) return;
          if (!hasKnownClassLock()) return;
          if (hasVisibleFullscreenOverlay()) return;

          const staleClasses = knownLockClasses.filter((className) => document.body.classList.contains(className));
          if (!staleClasses.length) return;

          document.body.classList.remove(...staleClasses);
          document.body.style.overflow = '';
        };

        const applyLockState = () => {
          if (!document.body) return;

          if (activeLocks.size > 0) {
            document.body.style.overflow = 'hidden';
            return;
          }

          if (document.body.style.overflow === 'hidden') {
            document.body.style.overflow = '';
          }
        };

        const clearGhostLock = (reason = 'unknown') => {
          if (!document.body) return;
          clearStaleClassLocks(reason);
          if (activeLocks.size > 0) return;

          const bodyInlineLocked = document.body.style.overflow === 'hidden';
          const htmlInlineLocked = document.documentElement.style.overflow === 'hidden';
          if (!bodyInlineLocked && !htmlInlineLocked) return;

          document.body.style.overflow = '';
          if (htmlInlineLocked) {
            document.documentElement.style.overflow = '';
          }
        };

        window.themeScrollLock = {
          lock(source) {
            if (!source) return;
            activeLocks.add(source);
            applyLockState();
          },
          unlock(source) {
            if (source) {
              activeLocks.delete(source);
            }
            applyLockState();
          },
          sync() {
            applyLockState();
          },
          clearGhostLock,
          getActiveLocks() {
            return Array.from(activeLocks);
          },
        };

        const init = () => {
          syncAnnouncementOffset();
          applyLockState();
          clearGhostLock('dom-ready');
          setTimeout(syncAnnouncementOffset, 250);
          setTimeout(syncAnnouncementOffset, 1200);
          setTimeout(() => clearGhostLock('post-load-1200ms'), 1200);
          setTimeout(() => clearGhostLock('post-load-2500ms'), 2500);

          window.addEventListener('pageshow', () => {
            syncAnnouncementOffset();
            applyLockState();
            clearGhostLock('pageshow');
          });

          window.addEventListener('resize', syncAnnouncementOffset);

          window.addEventListener('theme:scroll-lock-sync', () => {
            syncAnnouncementOffset();
            applyLockState();
            clearGhostLock('theme:scroll-lock-sync');
          });

          let scrollSafetyTimer = null;
          window.addEventListener('scroll', () => {
            if (scrollSafetyTimer) return;
            scrollSafetyTimer = setTimeout(() => {
              scrollSafetyTimer = null;
              if (activeLocks.size === 0 && document.body.style.overflow === 'hidden') {
                clearGhostLock('scroll-safety');
              }
            }, 200);
          }, { passive: true });

          setInterval(() => {
            if (activeLocks.size === 0) {
              clearGhostLock('periodic-check');
            }
          }, 3000);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
          init();
        }
      })();
    </script>

    <!-- Swiper.js JS -->
    <script defer src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  </body>
</html>
